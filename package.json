{
  "name": "synesthetic-code-craft",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "start": "vite",
    "serve": "vite",
    "start:intro": "MOTION_CANVAS_PROJECT=./src/projects/youtube-intro.ts vite",
    "start:deep-dive": "MOTION_CANVAS_PROJECT=./src/projects/youtube-deep-dive.ts vite",
    "start:patterns": "MOTION_CANVAS_PROJECT=./src/projects/patterns.ts vite",
    "build": "tsc && vite build",
    "build:intro": "tsc && MOTION_CANVAS_PROJECT=./src/projects/youtube-intro.ts vite build",
    "build:deep-dive": "tsc && MOTION_CANVAS_PROJECT=./src/projects/youtube-deep-dive.ts vite build",
    "build:patterns": "tsc && MOTION_CANVAS_PROJECT=./src/projects/patterns.ts vite build",
    "start:showcase-experiments": "MOTION_CANVAS_PROJECT=./src/projects/showcase-experiments.ts vite",
    "build:showcase-experiments": "tsc && MOTION_CANVAS_PROJECT=./src/projects/showcase-experiments.ts vite build",
    "start:backpropagation": "MOTION_CANVAS_PROJECT=./src/projects/backpropagation-basics.ts vite",
    "build:backpropagation": "tsc && MOTION_CANVAS_PROJECT=./src/projects/backpropagation-basics.ts vite build",
    "screenshots": "node scripts/generate-video-screenshots.mjs",
    "screenshots:backpropagation": "node scripts/generate-video-screenshots.mjs backpropagation-basics",
    "narration:backpropagation": "node scripts/timeline-to-say.mjs content/videos/backpropagation/04-timeline.md --out artifacts/narration/backpropagation.say.txt",
    "narration:backpropagation:audio": "node scripts/timeline-to-say.mjs content/videos/backpropagation/04-timeline.md --out artifacts/narration/backpropagation.say.txt --audio artifacts/narration/backpropagation.aiff",
    "narration:backpropagation:speak": "node scripts/timeline-to-say.mjs content/videos/backpropagation/04-timeline.md --out artifacts/narration/backpropagation.say.txt --speak",
    "narration:containers": "node scripts/timeline-to-say.mjs content/videos/containers-image-to-running-process/04-narration.md --out artifacts/narration/containers-image-to-running-process.say.txt",
    "narration:containers:audio": "node scripts/timeline-to-say.mjs content/videos/containers-image-to-running-process/04-narration.md --out artifacts/narration/containers-image-to-running-process.say.txt --audio artifacts/narration/containers-image-to-running-process.aiff",
    "narration:containers:speak": "node scripts/timeline-to-say.mjs content/videos/containers-image-to-running-process/04-narration.md --out artifacts/narration/containers-image-to-running-process.say.txt --speak",
    "start:containers": "MOTION_CANVAS_PROJECT=./src/projects/containers-image-to-running-process.ts vite",
    "build:containers": "tsc && MOTION_CANVAS_PROJECT=./src/projects/containers-image-to-running-process.ts vite build",
    "start:containers2": "MOTION_CANVAS_PROJECT=./src/projects/containers-to-running-processes-2.ts vite",
    "build:containers2": "tsc && MOTION_CANVAS_PROJECT=./src/projects/containers-to-running-processes-2.ts vite build",
    "screenshots:containers": "node scripts/generate-video-screenshots.mjs containers-image-to-running-process",
    "screenshots:containers:alive": "node scripts/generate-video-screenshots.mjs containers-image-to-running-process-alive",
    "screenshot:frame": "node scripts/capture-motion-canvas-frame.mjs",
    "screenshots:showcase-experiments": "node scripts/generate-video-screenshots.mjs showcase-experiments",
    "narration:openai-tts": "node scripts/openai-tts.mjs",
    "narration:openai-tts:cohesive": "node scripts/openai-tts-cohesive.mjs",
    "narration:extract-segment": "node scripts/extract-narration-segment.mjs",
    "start:splash": "MOTION_CANVAS_PROJECT=./src/projects/brand-splash.ts vite",
    "narrate:generate": "node scripts/generate-narration-simple.mjs",
    "narrate:say": "node scripts/generate-narration-say-timed.mjs",
    "narrate:espeak": "node scripts/generate-narration-audio.mjs --use-espeak",
    "audio:mux": "node scripts/mux-narration-audio.mjs"
  },
  "dependencies": {
    "@motion-canvas/2d": "^3.18.0-alpha.0",
    "@motion-canvas/core": "^3.18.0-alpha.0",
    "@motion-canvas/ffmpeg": "^3.18.0-alpha.0",
    "matter-js": "^0.20.0",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@motion-canvas/ui": "^3.18.0-alpha.0",
    "@motion-canvas/vite-plugin": "^3.18.0-alpha.0",
    "@types/matter-js": "^0.20.2",
    "@types/three": "^0.185.1",
    "typescript": "^5.2.2",
    "vite": "^4.0.0"
  }
}
